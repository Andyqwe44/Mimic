# === Build outputs ===
**/build/
**/build_dev/
release/*
!release/.gitkeep
*.exe
*.obj
*.o
*.dll
*.lib
*.exp
*.pdb
*.ilk
*.res

# WebView2 runtime cache (auto-generated next to .exe)
**/*.exe.WebView2/
test_target/build/
test_target/**/WebView2UserData/

# Generated code
monitor_app/src/embedded_assets.h

# Vite / frontend dist (staged by Build.ps1 into monitor_app/build*)
monitor_web/dist/
controller_web/dist/

# === Dependencies ===
**/node_modules/

# Signaling server runtime
signaling_server/data/
mimic_server/data/

# CDN helper scratch on local (remote nginx conf backups stay on server)
scripts/cdn/*.bak
scripts/cdn/nginx.conf.remote.bak
scripts/cdn/_probe_remote.ps1
scripts/cdn/_probe_8443.ps1
scripts/cdn/_release_*.log

# === Python ===
__pycache__/
*.py[cod]
*.pkl

# === IDE / Editor ===
.vscode/
.idea/
*.sln
*.vcxproj
*.vcxproj.filters
*.user
*.suo

# === OS ===
.DS_Store
Thumbs.db
desktop.ini

# === Logs ===
log/
**/log/
ai/logs/

# === Secrets ===
# Update-signing private key (public key lives in monitor_app/src/update_pubkey.h)
scripts/.signing/

# === Temp / Scratch ===
tmp/
*.tmp
*.bak
*.original.md

# === Test artifacts ===
test/frames/*.bgra
test/video.mp4

scripts/cdn/_last_release_dryrun.log
