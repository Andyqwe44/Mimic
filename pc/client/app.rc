// app.rc — exe icon + version metadata for monitor_app.exe (prod).
// Compiled by build.cmd:  rc.exe /nologo /fo build\app.res app.rc
#include <windows.h>
#include "src/version.h"

// Lowest icon ID → the icon Explorer/taskbar uses for the exe.
#define IDI_APPICON 1
IDI_APPICON ICON "app.ico"

VS_VERSION_INFO VERSIONINFO
  FILEVERSION    APP_VERSION_RC
  PRODUCTVERSION APP_VERSION_RC
  FILEFLAGSMASK  0x3fL
  FILEFLAGS      0x0L
  FILEOS         VOS_NT_WINDOWS32
  FILETYPE       VFT_APP
  FILESUBTYPE    0x0L
BEGIN
  BLOCK "StringFileInfo"
  BEGIN
    BLOCK "040904b0"   // US English (0x0409), Unicode (0x04b0 = 1200)
    BEGIN
      VALUE "CompanyName",      "Game Agent"
      VALUE "FileDescription",  "Game Agent Monitor"
      VALUE "FileVersion",      APP_VERSION
      VALUE "InternalName",     "monitor_app"
      VALUE "OriginalFilename", "monitor_app.exe"
      VALUE "ProductName",      "Game Agent Monitor"
      VALUE "ProductVersion",   APP_VERSION
      VALUE "LegalCopyright",   "Game Agent"
    END
  END
  BLOCK "VarFileInfo"
  BEGIN
    VALUE "Translation", 0x409, 1200
  END
END
